{
  "name": "@kazuhi-ra/turnbox-vue",
  "version": "0.2.1",
  "description": "Vue TurnBox — CSS3 3D box flip animation compound component and composable for Vue 3",
  "keywords": [
    "3d",
    "animation",
    "css3",
    "transform",
    "turnbox",
    "vue",
    "composable",
    "component"
  ],
  "license": "MIT",
  "author": "kazuhi-ra",
  "repository": {
    "type": "git",
    "url": "https://github.com/kazuhi-ra/turnbox.git",
    "directory": "packages/vue"
  },
  "homepage": "https://github.com/kazuhi-ra/turnbox#readme",
  "bugs": {
    "url": "https://github.com/kazuhi-ra/turnbox/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": ">=3"
  },
  "dependencies": {
    "@kazuhi-ra/turnbox-core": "workspace:^",
    "@kazuhi-ra/turnbox-dom": "workspace:*"
  },
  "devDependencies": {
    "@vue/server-renderer": "^3.5.34",
    "@vue/test-utils": "^2",
    "vue": "^3"
  }
}
