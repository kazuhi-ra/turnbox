{
  "name": "turnbox_js",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.11.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "turbo run build",
    "storybook": "storybook dev -p 6006",
    "lint": "biome lint packages/ tests/",
    "lint:fix": "biome lint --write packages/ tests/",
    "format": "biome format --write packages/ tests/ package.json packages/*/package.json",
    "format:check": "biome format packages/ tests/ package.json packages/*/package.json",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "prerelease": "pnpm run build && pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm test",
    "release": "pnpm -r publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@storybook/react-vite": "^10.4.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^3.2.0",
    "@vue/test-utils": "^2",
    "jquery": "1.12.4",
    "jsdom": "^26.1.0",
    "react": "^18",
    "react-dom": "^18",
    "storybook": "^10.4.0",
    "tsup": "^8.5.1",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0",
    "vue": "^3"
  }
}
